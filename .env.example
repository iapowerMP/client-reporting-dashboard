# ============================================================================
#  Variables de entorno. Copia a .env (local) y/o defínelas en Vercel.
#  NUNCA subas .env con valores reales al repositorio.
# ============================================================================

# Modo de datos del dashboard: "mock" (por defecto) | "live"
VITE_DATA_MODE=mock

# --- Supabase (lo usan las Vercel Functions /api, en el servidor) ----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# uuid del cliente en la tabla `clients` de Supabase (el mismo que se usa en
# el nodo "Config" del workflow de n8n que ingiere sus datos).
DASHBOARD_CLIENT_ID=

# --- Google Ads (lo usa n8n para la ingesta; NO el navegador) --------------
# El developer token requiere aprobación de Google.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
