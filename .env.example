# ============================================================================
#  Variables de entorno. Copia a .env (local) y/o defínelas en Vercel.
#  NUNCA subas .env con valores reales al repositorio.
# ============================================================================

# --- Supabase (lo usan las Vercel Functions /api, en el servidor) ----------
# Un único deployment sirve a todos los clientes: cada uno se identifica por
# su slug en la URL (/c/<slug>/...), resuelto en el servidor contra la tabla
# `clients`. No hace falta ninguna variable de entorno por cliente.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Nota: Google Ads (developer token, credenciales OAuth del System User/MCC)
# no usa variables de entorno aquí — vive enteramente en la credencial de
# n8n (nodo "Google Ads search"), no en el servidor de este dashboard.

# --- Autenticación ----------------------------------------------------------
# Contraseña del panel de administración general (/admin, ve todos los
# informes). Defínela solo en Vercel, no en el navegador.
ADMIN_PASSWORD=
# Secreto para firmar los tokens de sesión (contraseña por informe + admin).
# Genera uno aleatorio largo, p. ej.: openssl rand -hex 32
AUTH_TOKEN_SECRET=

# --- Sincronización manual (lo usa /api/sync-source) ------------------------
# URL del webhook de n8n que fuerza la sincronización inmediata de una fuente
# concreta. Cada una incluye un token en la propia URL, trátalas como
# secretos: solo en Vercel, nunca en el navegador ni en el repo.
N8N_GADS_SYNC_WEBHOOK_URL=
N8N_META_SYNC_WEBHOOK_URL=
N8N_GA4_SYNC_WEBHOOK_URL=

# --- Meta Ads: conexión con inicio de sesión (Facebook Login) ---------------
# Alternativa al modo API (System User + Business Manager): el propio project
# manager/cliente inicia sesión con su Facebook y concede acceso a las
# cuentas que él mismo administra, sin límite de partners de BM. Requiere el
# producto "Facebook Login for Business" en la misma app de Meta y permiso
# ads_read aprobado en App Review (Advanced Access) para usuarios ajenos al
# equipo. Usados por /api/oauth-meta-*.
META_APP_ID=
META_APP_SECRET=
# URL completa y exacta (debe coincidir con la registrada en la app de Meta):
# https://<tu-dominio>/api/oauth-meta-callback
META_OAUTH_REDIRECT_URI=
# Origen público del dashboard, para construir el redirect final tras el
# login (por defecto usa el dominio de producción de Vercel si se omite).
PUBLIC_APP_URL=

# --- GA4: conexión con inicio de sesión (Google) — único modo, sin API manual --
# El propio project manager/cliente inicia sesión con su Google y elige la
# propiedad GA4 que él mismo administra. Reutiliza el mismo cliente OAuth de
# Google Cloud que ya exista en el proyecto (añadiéndole el scope
# analytics.readonly y esta URL de redirección). Usados por /api/oauth-ga4-*.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# URL completa y exacta (debe coincidir con la registrada en el cliente OAuth):
# https://<tu-dominio>/api/oauth-ga4-callback
GOOGLE_OAUTH_REDIRECT_URI=
